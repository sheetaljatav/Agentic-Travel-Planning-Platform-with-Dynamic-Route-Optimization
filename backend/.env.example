# ============================================================
#  Agentic Travel Planning Platform — backend configuration
#  Every external data API has a FREE, no-billing default.
#  Keys below are OPTIONAL: absent keys fall back to free
#  providers or documented heuristics, so the app always runs.
# ============================================================

# ---- Core ----
APP_ENV=development                       # development | production
LOG_LEVEL=info                            # debug | info | warning | error
CORS_ORIGINS=http://localhost:5173        # comma-separated frontend origins

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/travel

# ---- LLM (LangGraph planner/extraction) ----
# Default provider is Anthropic. Leave ANTHROPIC_API_KEY blank to run the
# graph with a deterministic rule-based planner fallback (no LLM calls).
ANTHROPIC_API_KEY=
LLM_PLANNER_MODEL=claude-opus-4-8         # reasoning / decomposition
LLM_EXTRACT_MODEL=claude-haiku-4-5        # light extraction
# Optional: OpenAI-compatible endpoint instead of Anthropic
LLM_OPENAI_BASE_URL=
LLM_OPENAI_API_KEY=

# ---- Maps provider ----
# If GOOGLE_MAPS_API_KEY is set -> GoogleMapsProvider (Places/Directions/Matrix).
# Otherwise -> OpenRouteService (matrix/directions) + Nominatim (geocode), free.
GOOGLE_MAPS_API_KEY=
ORS_API_KEY=                              # free key from openrouteservice.org (2000 req/day)
NOMINATIM_USER_AGENT=agentic-travel-planner/1.0 (contact@example.com)

# ---- POI / attractions ----
OPENTRIPMAP_API_KEY=                      # free key from opentripmap.io; Wikipedia fallback if blank

# ---- Booking / pricing enrichment (optional, free test tier) ----
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# ---- FX (currency normalization) ----
FX_BASE_URL=https://open.er-api.com/v6/latest   # free, no key

# ---- Resilience knobs ----
HTTP_TIMEOUT_S=8
HTTP_MAX_RETRIES=3
BREAKER_FAIL_THRESHOLD=5
BREAKER_RESET_S=30
